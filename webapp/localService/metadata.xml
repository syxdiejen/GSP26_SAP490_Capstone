<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="1.0"
    xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx">
    <edmx:DataServices
        m:DataServiceVersion="2.0"
        xmlns:m="http://schemas.microsoft.com/ado/2007/08/dataservices/metadata">

        <Schema Namespace="EmailModel"
            xmlns="http://schemas.microsoft.com/ado/2008/09/edm">

            <EntityType Name="EmailTemplate">
                <Key>
                    <PropertyRef Name="TemplateID"/>
                </Key>

                <Property Name="TemplateID" Type="Edm.String" Nullable="false"/>
                <Property Name="Name" Type="Edm.String"/>
                <Property Name="Subject" Type="Edm.String"/>
                <Property Name="Body" Type="Edm.String"/>
                <Property Name="CreatedBy" Type="Edm.String"/>
                <Property Name="CreatedAt" Type="Edm.DateTime"/>
                <Property Name="Status" Type="Edm.String"/>
            </EntityType>

        </Schema>

        <Schema Namespace="EmailContainer"
            xmlns="http://schemas.microsoft.com/ado/2008/09/edm">

            <EntityContainer Name="EmailContainer" m:IsDefaultEntityContainer="true">
                <EntitySet Name="EmailTemplates"
                    EntityType="EmailModel.EmailTemplate"/>
            </EntityContainer>

        </Schema>
    </edmx:DataServices>
</edmx:Edmx>