<mvc:View
    controllerName="zemail.template.app.controller.template.Detail"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:rte="sap.ui.richtexteditor">

    <Page
        title="Template Preview"
        showNavButton="true"
        navButtonPress=".onNavBack">

        <headerContent>
            <Button
                text="Send Email"
                type="Emphasized"
                icon="sap-icon://email"
                press=".onSendEmailPress" />
        </headerContent>

        <content>
            <VBox class="detailPageWrapper sapUiSmallMargin">

                <Panel headerText="Receiver Information" class="sapUiSmallMarginBottom">
                    <VBox class="sapUiSmallMargin">
                        <Label text="To" required="true" />
                        <Input value="{mailForm>/to}" placeholder="user1@mail.com,user2@mail.com" />

                        <Label text="CC" class="sapUiSmallMarginTop" />
                        <Input value="{mailForm>/cc}" placeholder="cc1@mail.com,cc2@mail.com" />

                        <Label text="BCC" class="sapUiSmallMarginTop" />
                        <Input value="{mailForm>/bcc}" placeholder="bcc1@mail.com,bcc2@mail.com" />

                        <Label text="Reply-To" class="sapUiSmallMarginTop" />
                        <Input value="{mailForm>/replyTo}" placeholder="reply@mail.com" />
                    </VBox>
                </Panel>

                <Panel
                    headerText="Detected Variables"
                    class="sapUiSmallMarginBottom"
                    visible="{= ${variables>/items}.length > 0 }">
                    <VBox class="sapUiSmallMargin">
                        <List
                            items="{variables>/items}"
                            growing="false"
                            showSeparators="Inner">
                            <CustomListItem>
                                <VBox class="sapUiTinyMarginTop sapUiTinyMarginBottom">
                                    <Label text="{variables>name}" />
                                    <Input
                                        value="{variables>value}"
                                        liveChange=".onVariableValueChange"
                                        placeholder="Nhập giá trị cho {variables>token}" />
                                    <Text text="{variables>token}" class="sapUiTinyMarginTop" />
                                </VBox>
                            </CustomListItem>
                        </List>

                        <HBox
                            justifyContent="End"
                            class="sapUiSmallMarginTop">
                            <Button
                                text="Reset Body"
                                type="Transparent"
                                press=".onResetBodyPress"
                                class="sapUiTinyMarginEnd" />
                            <Button
                                text="Apply Variables"
                                type="Emphasized"
                                press=".onApplyVariablesPress" />
                        </HBox>
                    </VBox>
                </Panel>

                <HBox
                    class="previewToolbar sapUiSmallMarginBottom"
                    justifyContent="End"
                    alignItems="Center">
                    <SegmentedButton
                        selectedKey="desktop"
                        selectionChange=".onPreviewModeChange">
                        <items>
                            <SegmentedButtonItem key="desktop" icon="sap-icon://desktop-mobile" />
                            <SegmentedButtonItem key="tablet" icon="sap-icon://tablet-2" />
                            <SegmentedButtonItem key="mobile" icon="sap-icon://iphone" />
                        </items>
                    </SegmentedButton>
                </HBox>

                <VBox
                    id="previewWrapper"
                    class="emailPreviewShell previewDesktop">

                    <Panel class="emailCard">
                        <headerToolbar>
                            <OverflowToolbar>
                                <Title text="Email Preview" level="H4" />
                                <ToolbarSpacer />
                                <ObjectStatus
                                    text="{
                                        path: 'preview>/IsActive',
                                        formatter: '.formatter.statusText'
                                    }"
                                    state="{
                                        path: 'preview>/IsActive',
                                        formatter: '.formatter.statusState'
                                    }" />
                            </OverflowToolbar>
                        </headerToolbar>

                        <content>
                            <VBox class="emailHeader sapUiSmallMargin">

                                <HBox class="emailMetaRow sapUiTinyMarginBottom" wrap="NoWrap">
                                    <Text text="From:" class="emailMetaLabel" />
                                    <Text text="{mailForm>/replyTo}" class="emailMetaValue" />
                                </HBox>

                                <HBox class="emailMetaRow sapUiTinyMarginBottom" wrap="NoWrap">
                                    <Text text="To:" class="emailMetaLabel" />
                                    <Text text="{mailForm>/to}" class="emailMetaValue" />
                                </HBox>

                                <HBox class="emailMetaRow sapUiTinyMarginBottom" wrap="NoWrap" visible="{= !!${mailForm>/cc} }">
                                    <Text text="CC:" class="emailMetaLabel" />
                                    <Text text="{mailForm>/cc}" class="emailMetaValue" />
                                </HBox>

                                <HBox class="emailMetaRow sapUiTinyMarginBottom" wrap="NoWrap" visible="{= !!${mailForm>/bcc} }">
                                    <Text text="BCC:" class="emailMetaLabel" />
                                    <Text text="{mailForm>/bcc}" class="emailMetaValue" />
                                </HBox>

                                <HBox class="emailMetaRow" wrap="NoWrap">
                                    <Text text="Subject:" class="emailMetaLabel" />
                                    <Input value="{preview>/Subject}" width="100%" />
                                </HBox>
                            </VBox>

                            <VBox class="emailBody sapUiSmallMargin">
                                <HBox justifyContent="End" class="sapUiSmallMarginBottom">
                                    <SegmentedButton
                                        selectedKey="{ui>/bodyEditMode}"
                                        selectionChange=".onBodyEditModeChange">
                                        <items>
                                            <SegmentedButtonItem key="visual" text="Visual" icon="sap-icon://edit" />
                                            <SegmentedButtonItem key="html" text="HTML Source" icon="sap-icon://source-code" />
                                        </items>
                                    </SegmentedButton>
                                </HBox>

                                <rte:RichTextEditor
                                    id="htmlEditor"
                                    width="100%"
                                    height="500px"
                                    value="{preview>/BodyContent}"
                                    editable="true"
                                    visible="{= ${ui>/bodyEditMode} === 'visual' }"
                                    showGroupFont="true"
                                    showGroupLink="true"
                                    showGroupInsert="true"
                                    showGroupStructure="true"
                                    showGroupTextAlign="true" />

                                <TextArea
                                    id="htmlSourceEditor"
                                    value="{preview>/BodyContent}"
                                    liveChange=".onBodyContentLiveChange"
                                    visible="{= ${ui>/bodyEditMode} === 'html' }"
                                    width="100%"
                                    rows="25"
                                    growing="false"
                                    placeholder="Nhập HTML source tại đây..." />
                            </VBox>
                        </content>
                    </Panel>
                </VBox>
            </VBox>
        </content>
    </Page>
</mvc:View>