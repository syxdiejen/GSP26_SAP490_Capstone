<mvc:View
    controllerName="zemail.template.app.controller.template.EmailTemplateCreate"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:form="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:code="sap.ui.codeeditor"
    xmlns:rte="sap.ui.richtexteditor">

    <f:DynamicPage showFooter="true" busy="{create>/busy}">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{create>/title}" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <Wizard id="createWizard">
                
                <WizardStep id="stepBasic" title="Basic Information" validated="false">
                    <form:SimpleForm editable="true" layout="ResponsiveGridLayout">
                        <Label text="Template Name" />
                        <Input value="{create>/templateName}" required="true" liveChange=".onTemplateNameChange"/>

                        <Label text="Department" />
                        <Input value="{create>/department}" />

                        <Label text="Category" />
                        <Select selectedKey="{create>/category}">
                            <core:Item key="Sales" text="" />
                            <core:Item key="Marketing" text="Marketing" />
                            <core:Item key="System" text="System" />
                        </Select>

                        <Label text="Subject" />
                        <Input value="{create>/subject}" />
                    </form:SimpleForm>
                </WizardStep>

                <WizardStep id="stepContent" title="Email Content" validated="true">
                     <l:Grid defaultSpan="XL8 L8 M12 S12">
                        <VBox width="100%">
                            <SegmentedButton selectedKey="{create>/editorMode}">
                                <items>
                                    <SegmentedButtonItem key="RTE" text="Rich Text"/>
                                    <SegmentedButtonItem key="HTML" text="HTML Code"/>
                                </items>
                            </SegmentedButton>

                            <rte:RichTextEditor
                                id="emailRTE"
                                visible="{= ${create>/editorMode} === 'RTE' }"
                                value="{create>/bodyHtml}"
                                change=".onBodyHtmlChange"
                                width="100%"
                                height="500px"
                                sanitizeValue="false"/>

                            <code:CodeEditor
                                id="emailCode"
                                visible="{= ${create>/editorMode} === 'HTML' }"
                                value="{create>/bodyHtml}"
                                change=".onBodyHtmlChange"
                                type="html"
                                height="500px"
                                width="100%"/>
                        </VBox>

                        <IconTabBar expandable="false">
                            <items>
                                <IconTabFilter text="Variables">
                                    <List items="{path: 'create>/availableVariables'}">
                                        <StandardListItem
                                            title="{create>label}"
                                            description="{create>description}"
                                            type="Active"
                                            press=".onInsertVariable"/>
                                    </List>
                                </IconTabFilter>

                                <IconTabFilter text="Help">
                                    <VBox class="sapUiSmallMargin">
                                        <Text text="Use inline CSS for best email client compatibility."/>
                                        <Text text="Example: &lt;div style='color:red'&gt;Hello&lt;/div&gt;"/>
                                        <Text text="Supported placeholders: &amp;CUSTOMER_NAME&amp;, &amp;ORDER_ID&amp; ..."/>
                                    </VBox>
                                </IconTabFilter>
                            </items>
                        </IconTabBar>
                    </l:Grid>
                </WizardStep>

                <WizardStep id="stepVariables" title="Variable Mapping" activate=".onScanVariables" validated="true">
                    <Table items="{create>/usedVariables}" noDataText="No variables found in the content.">
                        <headerToolbar>
                            <OverflowToolbar>
                                <Title text="Detected Variables" />
                                <ToolbarSpacer />
                                <Button
                                    text="Rescan"
                                    type="Transparent"
                                    press=".onRescanVariables" />
                            </OverflowToolbar>
                        </headerToolbar>
                        <columns>
                            <Column><Text text="Variable Token"/></Column>
                            <Column><Text text="System Mapping/Description"/></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <ObjectIdentifier title="{create>name}" />
                                    <Text text="{create>description}" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </WizardStep>

                <WizardStep id="stepPreview" title="Preview Email" activate=".onPreview" validated="true">
                    <Panel headerText="Email Preview" class="sapUiResponsiveMargin">
                        <core:HTML id="emailPreviewHtml" preferDOM="false" content="{create>/previewHtml}" />
                    </Panel>
                </WizardStep>

            </Wizard>
        </f:content>

        <f:footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    text="Cancel"
                    type="Transparent"
                    press=".onCancelPress"
                    enabled="{= !${create>/busy} }" />
                <Button
                    text="Save Draft"
                    type="Transparent"
                    press=".onSaveDraft"
                    enabled="{= !${create>/busy} }" />
                <Button
                    text="Save &amp; Activate"
                    type="Emphasized"
                    press=".onSaveActivate"
                    enabled="{= !${create>/busy} }" />
            </OverflowToolbar>
        </f:footer>
    </f:DynamicPage>
</mvc:View>