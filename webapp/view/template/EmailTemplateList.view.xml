<mvc:View
    controllerName="zemail.template.app.controller.template.EmailTemplateList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f">

    <f:DynamicPage>
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>emailTemplateListTitle}" />
                </f:heading>

                <f:expandedContent>
                    <Label text="Manage reusable templates to standardize content and streamline creation workflows." />
                </f:expandedContent>

                <f:actions>
                    <Button icon="sap-icon://overflow" type="Transparent" />
                    <Button
                        text="Create Email"
                        type="Emphasized"
                        press=".onCreateEmail" />
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <HBox alignItems="Center" justifyContent="Start" wrap="Wrap">
                    <SearchField
                        width="300px"
                        placeholder="Search"
                        liveChange=".onSearch"
                        class="sapUiSmallMarginEnd" />

                    <Label text="Category" class="sapUiSmallMarginEnd" />

                    <Select
                        width="150px"
                        class="sapUiSmallMarginEnd"
                        change=".onCategoryChange">
                        <items>
                            <core:Item key="ALL" text="Show All" />
                                <core:Item key="Sales" />
                                <core:Item key="Marketing" text="Marketing" />
                                <core:Item key="System" text="System" />
                        </items>
                    </Select>

                    <Button
                        icon="sap-icon://filter"
                        type="Transparent"
                        text="More Filters" />
                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <Table
                id="emailTemplateTable"
                sticky="HeaderToolbar,ColumnHeaders"
                items="{email>/EmailTemplates}"
                growing="true"
                growingScrollToLoad="true">

                <columns>
                    <Column>
                        <Text text="Template Name" />
                    </Column>
                    <Column>
                        <Text text="Subject / Content Preview" />
                    </Column>
                    <Column>
                        <Text text="Department" />
                    </Column>
                    <Column>
                        <Text text="Category" />
                    </Column>
                    <Column width="5rem" hAlign="Center">
                        <Text text="Active" />
                    </Column>
                    <Column hAlign="End">
                        <Text text="Actions" />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem
                        type="Navigation"
                        press=".onItemPress">
                        <cells>
                            <VBox>
                                <Text text="{email>TemplateName}" />
                            </VBox>

                            <Text text="{email>Subject}" />

                            <Text text="{email>Department}" />

                            <Text text="{email>Category}" />

                            <Switch
                                state="{email>IsActive}"
                                customTextOn="✓"
                                customTextOff="—"
                                change=".onToggleActive" />

                            <HBox justifyContent="End">
                                <Button icon="sap-icon://edit" type="Transparent" press=".onEditTemplate" />
                                <Button icon="sap-icon://show" type="Transparent" press=".onPreviewTemplate" />
                                <Button icon="sap-icon://delete" type="Transparent" press=".onDeleteTemplate" />
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>