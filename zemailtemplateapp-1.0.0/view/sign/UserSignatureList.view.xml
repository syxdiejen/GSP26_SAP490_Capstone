<mvc:View
    controllerName="zemail.template.app.controller.sign.UserSignatureList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    >

    <f:DynamicPage id="signListPage">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>userSignaturesTitle}" level="H1" />
                </f:heading>

                <f:expandedContent>
                    <Label text="{i18n>userSignaturesSubtitle}" />
                </f:expandedContent>

                <f:actions>
                    <Button
                        text="{i18n>create}"
                        type="Emphasized"
                        icon="sap-icon://add"
                        press=".onCreatePress" />
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <HBox alignItems="Center" wrap="Wrap">
                    <SearchField
                        id="searchField"
                        width="320px"
                        placeholder="{i18n>searchBySignatureName}"
                        search=".onSearch"
                        class="sapUiSmallMarginEnd sapUiSmallMarginBottom" />

                    <Label
                        text="{i18n>type}"
                        class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginBottom" />

                    <Select
                        id="defaultFilter"
                        width="180px"
                        change=".onDefaultChange"
                        class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                        <items>
                            <core:Item key="ALL" text="{i18n>all}" />
                            <core:Item key="DEFAULT" text="{i18n>default}" />
                            <core:Item key="NONDEFAULT" text="{i18n>nonDefault}" />
                            <core:Item key="DRAFT" text="{i18n>draft}" />
                        </items>
                    </Select>

                    <Button
                        text="{i18n>go}"
                        type="Emphasized"
                        icon="sap-icon://search"
                        press=".onGoPress"
                        class="sapUiSmallMarginBottom" />
                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <Table
                id="signatureTable"
                sticky="ColumnHeaders,HeaderToolbar"
                mode="SingleSelectMaster"
                growing="true"
                growingScrollToLoad="true"
                inset="false"
                items="{
                    path: '/UserSignature'
                }">

                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{i18n>signatures}" level="H2" />
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="{i18n>signatureName}" />
                    </Column>

                    <Column width="8rem" hAlign="Center">
                        <Text text="{i18n>default}" />
                    </Column>

                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="{i18n>owner}" />
                    </Column>

                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="{i18n>lastChanged}" />
                    </Column>

                    <Column minScreenWidth="Tablet" demandPopin="true" hAlign="End">
                        <Text text="{i18n>actions}" />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem type="Navigation" press=".onItemPress">
                        <cells>
                            <VBox>
                                <HBox alignItems="Center" wrap="Wrap">
                                    <Text text="{SignName}" wrapping="false" />

                                    <ObjectStatus
                                        text="{i18n>draft}"
                                        state="Information"
                                        visible="{= ${IsActiveEntity} === false }"
                                        class="sapUiTinyMarginBegin" />

                                    <ObjectStatus
                                        text="{i18n>default}"
                                        state="Success"
                                        visible="{= ${IsDefault} === true }"
                                        class="sapUiTinyMarginBegin" />
                                </HBox>

                                <Text
                                    text="{i18n>unsavedChanges}"
                                    visible="{= ${HasDraftEntity} === true &amp;&amp; ${IsActiveEntity} === true }"
                                    class="sapUiTinyMarginTop sapUiTinyMarginBottom"
                                    wrapping="false" />
                            </VBox>

                            <ObjectStatus
                                text="{= ${IsDefault} ? ${i18n>yes} : ${i18n>no} }"
                                state="{= ${IsDefault} ? 'Success' : 'None' }" />

                            <Text text="{OwnerId}" />

                            <Text 
                                text="{
                                path: 'LastChangedAt',
                                type: 'sap.ui.model.type.DateTime',
                                formatOptions: {
                                    pattern: 'dd/MM/yyyy HH:mm:ss'
                                }
                            }" />

                            <HBox justifyContent="End">
                                <Button icon="sap-icon://edit" type="Transparent" press=".onEditPress" />
                                <Button icon="sap-icon://delete" type="Transparent" press=".onDeletePress" />
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>